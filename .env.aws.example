NODE_ENV=production
APP_NAME=pariflow-back
HOST=127.0.0.1
PORT=3001
API_PREFIX=api/v1
TRUST_PROXY=true

# Enquanto estiver sem dominio, use o IP publico da EC2 com http.
# Quando ativar dominio/HTTPS, troque para https://seu-dominio.
APP_URL=http://3.18.213.49
CORS_ORIGINS=http://3.18.213.49
COOKIE_SECURE=false

# Use DATABASE_URL completo OU os campos DB_* abaixo.
# DATABASE_URL=mysql://pariflow_user:<senha>@127.0.0.1:3306/pariflow_db
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=pariflow_user
DB_PASSWORD=<preencher-na-ec2>
DB_NAME=pariflow_db

JWT_ACCESS_SECRET=<minimo-32-caracteres>
JWT_REFRESH_SECRET=<minimo-32-caracteres>
JWT_ACCESS_TTL_MINUTES=10
JWT_REFRESH_TTL_DAYS=15

# Deixe false em producao real. Use true apenas para preview privado sem Firebase.
PREVIEW_AUTH_BYPASS=false
DEV_AUTH_BYPASS=false

FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

AWS_REGION=us-east-2
S3_BUCKET_PRIVATE=
SENSITIVE_SESSION_TTL_MINUTES=10

SEED_ADMIN_NAME=Administrador Inicial
SEED_ADMIN_EMAIL=
SEED_ADMIN_FIREBASE_UID=
SEED_ENABLE_SAMPLE_DATA=false
