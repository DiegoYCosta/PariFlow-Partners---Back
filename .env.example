NODE_ENV=development
HOST=127.0.0.1
PORT=3000
APP_NAME=pariflow-back
APP_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000
API_PREFIX=api/v1
LOG_LEVEL=log

# Use DATABASE_URL ou DB_*.
DATABASE_URL=mysql://user:password@127.0.0.1:3306/pariflow_db
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=pariflow_user
DB_PASSWORD=change-me
DB_NAME=pariflow_db

JWT_ACCESS_SECRET=change-this-access-secret-with-at-least-32-chars
JWT_ACCESS_TTL_MINUTES=10
JWT_REFRESH_SECRET=change-this-refresh-secret-with-at-least-32-chars
JWT_REFRESH_TTL_DAYS=15

COOKIE_DOMAIN=localhost
COOKIE_SECURE=false
DEV_AUTH_BYPASS=true
PREVIEW_AUTH_BYPASS=false
TRUST_PROXY=false

# Firebase Admin fica somente no backend. Nao copiar para o front.
FIREBASE_PROJECT_ID=pfp-yar-2
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

AWS_REGION=us-east-2
S3_BUCKET_PRIVATE=
SENSITIVE_SESSION_TTL_MINUTES=10

SEED_ADMIN_NAME=Administrador Local
SEED_ADMIN_EMAIL=dev@local.test
SEED_ADMIN_FIREBASE_UID=
SEED_ENABLE_SAMPLE_DATA=true
