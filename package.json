{
  "name": "pariflow-partners-back",
  "version": "0.1.0",
  "private": true,
  "description": "Backend base do PariFlow Partners com NestJS, Fastify, Prisma e autenticacao inicial via Firebase.",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "start:dev": "tsx watch src/main.ts",
    "lint": "tsc --noEmit",
    "db:local:setup": "powershell -ExecutionPolicy Bypass -File .\\scripts\\setup-local-mysql.ps1",
    "db:local:stop": "powershell -ExecutionPolicy Bypass -File .\\scripts\\stop-local-mysql.ps1",
    "prisma:format": "prisma format",
    "prisma:generate": "prisma generate",
    "prisma:migrate:status": "prisma migrate status",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:seed": "prisma db seed"
  },
  "dependencies": {
    "@fastify/cookie": "^10.0.1",
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^13.0.1",
    "@fastify/static": "^9.1.3",
    "@nestjs/common": "^11.1.6",
    "@nestjs/core": "^11.1.6",
    "@nestjs/jwt": "^11.0.1",
    "@nestjs/platform-fastify": "^11.1.6",
    "@nestjs/swagger": "^11.2.0",
    "@prisma/client": "^6.8.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "fastify": "^5.3.3",
    "firebase-admin": "^13.4.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "ulid": "^3.0.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.18",
    "prisma": "^6.8.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
